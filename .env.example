# ── Scheduler Configuration ──────────────────────────────────────────────────
# Set the time the nightly skill-capture pipeline runs.
# Uses 24-hour format. Defaults to 23:59 if not set.
SCHEDULE_HOUR=23
SCHEDULE_MINUTE=59

# ── LLM Provider ────────────────────────────────────────────────────────────
# Supported: openai | anthropic | gemini  (default: openai)
LLM_PROVIDER=openai

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini
# GOOGLE_API_KEY=...
# GEMINI_MODEL=gemini-2.0-flash
